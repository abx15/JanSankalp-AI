# Primary Auth Secret for JWT (nest-api)
AUTH_SECRET="jansankalp-jwt-secret-key-2026-production"
# NextAuth settings for client routing (frontend)
NEXTAUTH_SECRET="jansankalp-nextauth-secret-key-2026"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 3. AI / NLP / CV API KEYS (Used by fastapi-ai)
