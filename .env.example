# ------------------------------------------------------------------------------
# 1. DATABASE & REDIS (Shared)
# ------------------------------------------------------------------------------
# PostgreSQL Connection URL
DATABASE_URL="postgresql://jansankalp:jansankalp_pass@localhost:5432/jansankalp"
# Redis Cache & Queue Manager
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# 2. CORE SECURITY & SERVICE INTEGRATION (Shared)
# ------------------------------------------------------------------------------
# Inter-Service Authentication Token (verifies fastapi-ai and node-services endpoints)
