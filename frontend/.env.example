# ==============================================================================
# JanSankalp AI — Frontend Next.js Client (.env.example)
# ==============================================================================

# Next.js Application Environment & Port
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------------------------
# MICROSERVICES ENDPOINT ROUTING
# When deploying to Render, update these URLs to your live Render services:
# ------------------------------------------------------------------------------

# 1. NestJS Business Logic Gateway
NEXT_PUBLIC_API_URL="https://your-nest-api.onrender.com/api"
NEXT_PUBLIC_BASE_URL="https://your-nest-api.onrender.com"

# 2. FastAPI Python AI Engine Service
NEXT_PUBLIC_AI_URL="https://your-fastapi-ai.onrender.com"

# 3. Express Node Utility Service
NEXT_PUBLIC_UTILS_URL="https://your-node-services.onrender.com"

# ------------------------------------------------------------------------------
# FRONTEND CORE AUTHENTICATION (NextAuth)
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://your-frontend-app.onrender.com"
NEXTAUTH_SECRET="your-nextauth-secret-key"
AUTH_SECRET="your-jwt-auth-secret-key"

# ------------------------------------------------------------------------------
# SECURE MEDIA UPLOADS & IMAGERY
# ------------------------------------------------------------------------------
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="public_..."
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/..."

# ------------------------------------------------------------------------------
# MAP SERVICES & ANALYTICS
# ------------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN="pk..."
NEXT_PUBLIC_GA_ID="G-..."

# ------------------------------------------------------------------------------
# PRE-CONFIGURED DEMO USER PASSWORDS
# ------------------------------------------------------------------------------
ADMIN_PASSWORD="admin123"
OFFICER_PASSWORD="officer123"
CITIZEN_PASSWORD="citizen123"

# Prisma Database connection URL for API routes (Server Actions / API endpoints)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
