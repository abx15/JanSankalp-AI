# ==============================================================================
# JanSankalp AI — Frontend Next.js Client (Production Level Environment Template)
# Reference this file when configuring Environment Variables inside Vercel Dashboard!
# ==============================================================================

# Application Mode
NODE_ENV=production

# ------------------------------------------------------------------------------
# MICROSERVICES PRODUCTION ROUTING (Render Services Endpoints)
# Replace 'your-service-name' with your actual Render deployment subdomains.
# ------------------------------------------------------------------------------

# 1. NestJS Gateway Core API (Render Web Service)
# Maps to: backend/nest-api/
NEXT_PUBLIC_API_URL="https://your-nest-api.onrender.com/api"
NEXT_PUBLIC_BASE_URL="https://your-nest-api.onrender.com"

# 2. FastAPI Python AI Engine (Render Web Service)
# Maps to: backend/fastapi-ai/
NEXT_PUBLIC_AI_URL="https://your-fastapi-ai.onrender.com"

# 3. Express Node Utilities Service (Render Web Service)
# Maps to: backend/node-services/
NEXT_PUBLIC_UTILS_URL="https://your-node-services.onrender.com"

# ------------------------------------------------------------------------------
# AUTHENTICATION & SECURE COOKIES (NextAuth / JWT)
# ------------------------------------------------------------------------------
# NEXTAUTH_URL must match your final live Vercel domain URL:
NEXTAUTH_URL="https://jansankalp-ai.vercel.app"
NEXTAUTH_SECRET="I/9TpoQCI36gforZOYZ2MsOS7MjqWMdPwTBJW1WWQpg="
AUTH_SECRET="I/9TpoQCI36gforZOYZ2MsOS7MjqWMdPwTBJW1WWQpg="

# ------------------------------------------------------------------------------
# SECURE STORAGE & THIRD-PARTY MEDIA MANAGEMENT
# ------------------------------------------------------------------------------
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="public_81Hn+17o1UB5aotmt+2cQrFX2nE="
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/er7lmis3j"

# ------------------------------------------------------------------------------
# LIVE MAPS AND ANCHORED GEOLOCATION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-public-token"

# Google Analytics Tracker ID (Optional)
NEXT_PUBLIC_GA_ID="G-PRODUCTION-ID"

# ------------------------------------------------------------------------------
# DATABASE BINDING (Neon PostgreSQL Database URL)
# Needed if Next.js performs direct database requests via Prisma in Server Actions:
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
