# ==============================================================================
# JanSankalp AI — NestJS Core Gateway API Service (.env.example)
# ==============================================================================

# Service Port (Default: 4000)
PORT=4000

# PostgreSQL Connection URL (e.g. Neon, AWS RDS, Render PostgreSQL)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Redis Cache & Queue Manager URL
REDIS_URL="redis://localhost:6379"

# Core Security & Authentication (JWT Secret key)
AUTH_SECRET="your-jwt-auth-secret-key-production"

# Service-to-Service Internal Communication Token
# MUST match across nest-api, fastapi-ai, and node-services
INTERNAL_SERVICE_TOKEN="jansankalp-internal-secret-service-token-2026"

# Python FastAPI AI service endpoint
# LOCAL: http://localhost:8000
# RENDER DEPLOYMENT: https://your-fastapi-ai-service.onrender.com
AI_SERVICE_URL="http://localhost:8000"

# Express Node utility service endpoint
# LOCAL: http://localhost:3001
# RENDER DEPLOYMENT: https://your-node-services.onrender.com
NODE_SERVICES_URL="http://localhost:3001"

# Email dispatch integrations (SMTP or Resend)
RESEND_API_KEY="re_..."
SMTP_EMAIL="alerts@jansankalp.org"
SMTP_PASSWORD="your-smtp-password"

# Default Auth passwords for database seeding
ADMIN_PASSWORD="admin123"
OFFICER_PASSWORD="officer123"
CITIZEN_PASSWORD="citizen123"
