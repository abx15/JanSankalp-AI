# ==============================================================================
# JanSankalp AI — FastAPI Python AI Engine Service (.env.production)
# ==============================================================================

# Service Port
PORT=8000

# Service-to-Service Internal Communication Token
# Authenticates incoming requests from nest-api
INTERNAL_SERVICE_TOKEN="jansankalp-internal-secret-service-token-2026"

# LLM API Keys - Fill in your active production API keys on Render Environment Variables
OPENAI_API_KEY="sk-proj-your-openai-api-key"
GROK_API_KEY="xai-your-grok-api-key"
HUGGINGFACE_API_KEY="hf_your-huggingface-api-key"
COHERE_API_KEY="your-cohere-api-key"
ASSEMBLY_AI_API_KEY="your-assembly-ai-api-key"

# Configuration Mappings
EMBEDDING_MODEL="text-embedding-3-small"
SIMILARITY_THRESHOLD=0.85
