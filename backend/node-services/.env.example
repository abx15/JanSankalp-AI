# ==============================================================================
# JanSankalp AI — Express Node Utility Service (.env.example)
# ==============================================================================

# Service Port (Default: 3001)
PORT=3001
NODE_SERVICES_PORT=3001

# Environment status (production / development)
NODE_ENV=development

# Service-to-Service Internal Communication Token
# MUST match across all microservices
INTERNAL_SERVICE_TOKEN="jansankalp-internal-secret-service-token-2026"

# Core API Gateway (nest-api) internal url
# LOCAL: http://localhost:4000
# RENDER DEPLOYMENT: https://your-nest-api.onrender.com
NEST_API_INTERNAL_URL="http://localhost:4000"

# Secure Media Uploads (ImageKit parameters)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="public_..."
IMAGEKIT_PRIVATE_KEY="private_..."
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_endpoint"

# Billing & Subscriptions (Stripe parameters)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email dispatch integrations (SMTP / Resend fallback)
RESEND_API_KEY="re_..."
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_USER="resend"
SMTP_PASS="your-smtp-password"
SMTP_FROM="JanSankalp Alerts <alerts@jansankalp.org>"
